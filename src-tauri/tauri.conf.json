{
    "$schema": "https://raw.githubusercontent.com/nicegui/nicegui/refs/heads/main/nicegui/templates/tauri_conf_v2_schema.json",
    "productName": "AudioGraph",
    "identifier": "com.rsac.audiograph",
    "version": "0.1.0",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "bun run dev",
        "beforeBuildCommand": "bun run build"
    },
    "app": {
        "windows": [
            {
                "title": "AudioGraph",
                "width": 1400,
                "height": 900,
                "resizable": true,
                "fullscreen": false
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
        }
    },
    "bundle": {
        "macOS": {
            "entitlements": null,
            "exceptionDomain": null,
            "frameworks": [],
            "minimumSystemVersion": "14.4",
            "signingIdentity": null,
            "infoPlist": "Info.plist"
        }
    }
}